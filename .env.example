# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-in-production-use-256-bit-random
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=sentinelai
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel_dev

# ── OpenSearch ────────────────────────────────────────────────────────────────
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=admin

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=

# ── Kafka ─────────────────────────────────────────────────────────────────────
# Docker network: kafka:29092 | Host machine: localhost:9092
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_CONSUMER_GROUP=sentinelai-consumers

# ── LLM ───────────────────────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Threat Intel ──────────────────────────────────────────────────────────────
ABUSEIPDB_API_KEY=
OTX_API_KEY=
MALWARE_BAZAAR_API_KEY=

# ── GeoIP (optional – MaxMind GeoLite2) ───────────────────────────────────────
GEOIP_DB_PATH=data/geoip/GeoLite2-City.mmdb
GEOIP_ASN_DB_PATH=data/geoip/GeoLite2-ASN.mmdb
MAXMIND_LICENSE_KEY=

# ── Detection ─────────────────────────────────────────────────────────────────
SIGMA_RULES_DIR=data/sigma_rules
BEHAVIORAL_BRUTE_FORCE_THRESHOLD=10
BEHAVIORAL_BRUTE_FORCE_WINDOW=300
BEHAVIORAL_PASSWORD_SPRAY_THRESHOLD=5
BEHAVIORAL_PASSWORD_SPRAY_WINDOW=300
BEHAVIORAL_PORT_SCAN_THRESHOLD=20
BEHAVIORAL_PORT_SCAN_WINDOW=120

# ── Reporting ─────────────────────────────────────────────────────────────────
S3_BUCKET_REPORTS=sentinelai-reports
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
